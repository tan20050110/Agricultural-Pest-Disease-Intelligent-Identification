# =============================================================================
# 遥感目标智能检测平台 - 环境变量配置示例
# =============================================================================
# 使用说明：
#   1. 复制此文件为 .env：cp .env.example .env
#   2. 修改 .env 文件中的配置值为实际值
#   3. 不要将 .env 文件提交到版本控制系统！
#
# 配置优先级：
#   .env 文件中的值会覆盖 config.py 中的默认值
# =============================================================================

# =============================================================================
# 应用基本配置
# =============================================================================
APP_NAME=RSOD Detection Platform
APP_VERSION=1.0.0
DEBUG=true
HOST=0.0.0.0
PORT=8000

# =============================================================================
# PostgreSQL 数据库配置
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=rsod_user
DB_PASSWORD=your_secure_password_here
DB_DATABASE=rsod_platform

# =============================================================================
# Redis 缓存配置
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# =============================================================================
# MinIO 对象存储配置
# =============================================================================
MINIO_HOST=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=your_secure_password_here
MINIO_SECURE=false

# =============================================================================
# YOLO 目标检测模型配置
# =============================================================================
YOLO_MODEL_PATH=models/rsod_yolo11n/weights/best.pt
CONFIDENCE_THRESHOLD=0.3
IOU_THRESHOLD=0.45

# =============================================================================
# CORS 跨域配置（多个地址用逗号分隔）
# =============================================================================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
